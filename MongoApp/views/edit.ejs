<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Message</title>
</head>
<body>
    <h3>Edit your Message</h3>
    <p>Chat ID:  <%= chat._id %></p>
    <p>This message was sent from <i> <%= chat.from %></i> to <i><%= chat.to %> </i></p>
    <form action="/chats/:id" method="post">
        <textarea name="msg" rows="10"><%= chat.msg %></textarea><br>
        <button>Edit</button>
    </form>
</body>
</html>