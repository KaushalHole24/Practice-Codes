<% layout("/layouts/boilerplate") %>

    <body>
        <div class="row mt-3">
            <div class="col-6 offset-3 show-card">
                <h3>Listing Details : </h3>
            </div>

            <div class="card col-6 offset-3 show-card">
                <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing image">
                <div class="card-body">
                    <p class="card-text mt-3">
                        <b><%= listing.title %></b><br>
                        <%= listing.description %> <br>
                        &#8377; <%= listing.price.toLocaleString("en-IN") %> / night <br>
                        <%= listing.location %> <br>
                        <%= listing.country %> <br>
                    </p>
                </div>
            </div>

            <div class="btns col-6 offset-3 mb-3 show-card">
                <a class="btn btn-dark edit-btn" href="/listings/<%= listing._id %>/edit">Edit</a>
    
                <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
                    <button class="btn btn-dark">Delete</button>
                </form>
            </div>
        </div>

        
        
    </body>